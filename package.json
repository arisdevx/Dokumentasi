{
  "name": "dokumentasi",
  "version": "0.1.0",
  "description": "Lightweight static API documentation for humans and AI agents.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "npm run build && vite --host 127.0.0.1 dist",
    "build": "node src/build.js && tailwindcss -i src/styles/input.css -o dist/assets/styles.css --minify",
    "validate:docs": "node src/validate-docs.js",
    "clean": "node src/clean.js"
  },
  "keywords": [
    "api-documentation",
    "openapi",
    "markdown",
    "llms.txt",
    "static-site",
    "tailwindcss",
    "alpinejs"
  ],
  "license": "MIT",
  "dependencies": {
    "@tabler/icons": "^3.35.0",
    "alpinejs": "^3.14.9",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
